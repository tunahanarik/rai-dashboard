# ─── RAI Dashboard Configuration ───────────────────────────────────────────────

# HTTP RPC endpoint (used for /status and /net_info queries)
RPC_HTTP_URL=http://127.0.0.1:43657

# TCP RPC endpoint (used for CLI queries via republicd)
RPC_NODE_URL=tcp://127.0.0.1:43657

# Chain ID
CHAIN_ID=raitestnet_77701-1

# Default validator operator address (optional)
# DEFAULT_VALOPER=raivaloper1...

# Server port (binds to 127.0.0.1 only)
PORT=3000

# CORS allowed origins (comma-separated, default: same origin only)
# CORS_ORIGINS=https://dashboard.example.com

# Rate limit: max requests per window per IP
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
